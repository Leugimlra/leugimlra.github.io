---
import "@fontsource-variable/fira-code";
---

<head>
  <title>Miguel Lopez Rivera</title>
  <style is:global>
    body {
      background-color: #161717;
      color: whitesmoke;
      font-family: "Fira Code Variable", monospace;
      font-size: 1.2rem;
    }

    p,
    li,
    span {
      font-size: 1rem;
    }

    nav a:any-link {
      color: #81b622 !important;
    }

    h1,
    h2,
    h3,
    h4,
    h5,
    h6 {
      font-weight: bold;
    }
  </style>
</head>
