---
import "@fontsource-variable/fira-code";
import Navbar from "../components/navbar.astro";
---

<style>
  body {
    font-family: "Fira Code Variable", monospace;
    font-size: 1rem;
  }

  p,
  li,
  span,
  a {
    font-size: 1rem;
  }

  h1,
  h2,
  h3,
  h4,
  h5,
  h6 {
    font-weight: bold;
  }
</style>

<Navbar />
